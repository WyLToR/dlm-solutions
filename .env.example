# Shared root env for backend + frontend (local and Render-like testing)

# Backend
ASPNETCORE_ENVIRONMENT=Development
PORT=5190
Jwt__Key=replace-with-strong-random-key-min-32chars
ConnectionStrings__DefaultConnection=Server=localhost;Port=3306;Database=dlm-app;User Id=root;Password=root;SslMode=Disabled;

# Aiven MySQL (used by docker-compose phpMyAdmin too)
AIVEN_MYSQL_HOST=your-aiven-mysql-host
AIVEN_MYSQL_PORT=3306
AIVEN_MYSQL_USER=your-aiven-user
AIVEN_MYSQL_PASSWORD=your-aiven-password
AIVEN_MYSQL_DB=defaultdb
AIVEN_MYSQL_SSL=1

# Frontend (Vite dev proxy target)
VITE_API_URL=http://localhost:5190
